# Model API Key (required)
# Run `cody config setup` for interactive configuration (recommended).
CODY_MODEL_API_KEY=your_api_key_here

# Default model (optional)
CODY_MODEL=anthropic:claude-sonnet-4-0

# Custom OpenAI-compatible provider (optional)
# Use these to connect to Qwen, DeepSeek, GLM, or any OpenAI-compatible API.
# CODY_MODEL=glm-4
# CODY_MODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
