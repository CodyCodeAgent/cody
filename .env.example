# Anthropic API Key (used by pydantic-ai when no model_api_key is configured)
ANTHROPIC_API_KEY=your_api_key_here

# Default model (optional)
CODY_MODEL=anthropic:claude-sonnet-4-0

# Custom OpenAI-compatible provider (optional)
# Use these to connect to Qwen, DeepSeek, GLM, or any OpenAI-compatible API.
# CODY_MODEL=glm-4
# CODY_MODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# CODY_MODEL_API_KEY=your_provider_api_key_here

# Tip: Use `cody config setup` for interactive configuration instead of env vars.
