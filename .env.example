# Anthropic API Key (required for Anthropic models)
ANTHROPIC_API_KEY=your_api_key_here

# Claude OAuth token (alternative to API key, from `claude login`)
# When set, uses Anthropic OAuth authentication instead of API key.
# CLAUDE_OAUTH_TOKEN=your_oauth_token_here

# Default model (optional)
CODY_MODEL=claude-3-5-sonnet-20241022

# Custom OpenAI-compatible provider (optional)
# Use these to connect to 智谱 GLM, 阿里 DashScope, or any OpenAI-compatible API.
# CODY_MODEL=glm-4
# CODY_MODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# CODY_MODEL_API_KEY=your_provider_api_key_here
